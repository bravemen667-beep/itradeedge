# === EXCHANGE ===
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# === DATABASE ===
DATABASE_URL=postgresql://itradeedge:password@localhost:5432/itradeedge

# === FREQTRADE (VPS) ===
FREQTRADE_API_URL=https://trade.itradeedge.com/freqtrade/api/v1
FREQTRADE_API_USER=freqtrader
FREQTRADE_API_PASS=secure_password_here

# === FREQTRADE AUTH PROXY ===
FT_PROXY_BASE=https://your-vps.com/ftproxy/proxy
FT_PROXY_KEY=your_proxy_api_key

# === LUNARCRUSH ===
LUNARCRUSH_API_KEY=your_lunarcrush_api_key

# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# === REDIS ===
REDIS_URL=redis://:password@localhost:6379

# === APP ===
PAPER_TRADING=true
NODE_ENV=development

# === API AUTH (server-side / cross-origin callers) ===
# Optional. If set, requests to /api/* that are NOT same-origin browser
# requests must include `X-API-Key: <this value>`. /api/health is always
# public. Rate limit is 60 req/min per IP regardless of auth.
API_KEY=your_api_key_for_server_side_callers

# === VPS DOCKER ===
DB_PASSWORD=changeme
REDIS_PASSWORD=changeme
JWT_SECRET=changeme
ACME_EMAIL=admin@itradeedge.com
